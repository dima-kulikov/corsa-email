          </mj-text>
          <mj-text mj-class="fontSize-14 " color="#B4BED8" align="left">
            <!--TEXT-->
            Take advantage of Bonus
          </mj-text>
        </mj-column>
        </mj-group>
      </mj-section>

    <!-- BR-->
      <mj-section padding-bottom="12px">
        <mj-column width="100%">
        </mj-column>
      </mj-section>

            <mj-section full-width="full-width" padding="12px" css-class="bonus-steps">
      <mj-group>
        <mj-column css-class="bonus-steps-item-1"  vertical-align="middle" padding="0">
          <!--IMG GAME-->
          <mj-image src="./img/casino.jpg" alt="step" width="64px" height="64px"  align="left" />
        </mj-column>

        <mj-column  vertical-align="middle" padding="0" css-class="bonus-steps-item-2">
          <mj-text mj-class="fontSize-16 light" font-weight="700" align="left">
            <!--TEXT-->
            Step 3
          </mj-text>
          <mj-text mj-class="fontSize-14 " color="#B4BED8" align="left">
            <!--TEXT-->
            Take advantage of Bonus
          </mj-text>
        </mj-column>
        </mj-group>
      </mj-section>

    <!-- BR-->
      <mj-section padding-bottom="12px">
        <mj-column width="100%">
        </mj-column>
      </mj-section>

      <mj-section full-width="full-width" mj-class="padding-section" padding-bottom="40px">
       <mj-column width="100%" padding-bottom="24px">
          <mj-button href="https://mjml.io">
            <!--Button-->
            Claim
          </mj-button>
        </mj-column>

        <mj-column width="100%">
         <mj-text align="left" mj-class="fontSize-16 light">
            <!--Text-->
            To check if the offer is available and to activate the promotion, please contact our  <a href="https://mjml.io" target="_blank" style="color: #FFC700;">Live Chat 24/7</a>.
          </mj-text>
        </mj-column>
      </mj-section>

      <!--Footer-->
      <mj-section full-width="full-width"  mj-class="bg__footer">
      <mj-raw>
        <div style="width: 100%; height: 1px; background: #F5D36D; background: linear-gradient(270deg, rgba(245, 211, 109, 0) 0%, #F5D36D 48.96%, rgba(245, 211, 109, 0) 100%);"></div>
      </mj-raw>

        <mj-column width="44px" css-class="footer-img">
          <!-- Logo Footer Img -->
          <mj-image src="https://res.cloudinary.com/dvlpao67k/image/upload/v1710927404/Tahiti%20casino%20b2b/fonf3d5uyoqr7l3jkdkc.png" alt="footer-img" align="left" />
        </mj-column>

        <mj-column css-class="footer-unsubscribe">
          <mj-text mj-class="fontSize-12" align="left">
            <!--Text Link-->
            <a href="https://mjml.io" style="color:#FFC700">Unsubscribe</a>
          </mj-text>
        </mj-column>

        <mj-column width="40%" css-class="footer-copyright">
          <mj-text mj-class="fontSize-12" color="#FFFFFF" align="right">
            <!--Text-->
            Gambling can be addictive. Play responsibly. 2024 © Corsaza.com All rights reserved.
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>