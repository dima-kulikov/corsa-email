          </mj-text>

          <mj-button href="https://mjml.io" target="_blank" width="140px" padding="0" css-class="card-item-btn" background-color="#2F2F3D" border="0" color="#FFFFFF"  font-size="14px" inner-padding="8px 24px">
            <!--Button-->
            Reactoonz_1
          </mj-button>
        </mj-column>


        <mj-column css-class="bg_card" width="31%" padding="16px 6px">
          <!--BANNER IMG-->
          <mj-image src="./img/game-balls.jpg" width="80px" height="43px" padding="0 0 4px" alt=" money" />

          <mj-text align="center" mj-class="fontSize-16 light" font-weight="700">
            <!--Text-->
            BONUS 20 %
          </mj-text>

          <mj-text align="center" mj-class="fontSize-16 light" font-weight="700">
            <!--Text-->
            +60 Freespins
          </mj-text>

          <mj-text align="center" mj-class="fontSize-12 light" padding-bottom="12px">
            <!--Text-->
            in game
            <br>
            <span style="color: #FFC700; text-decoration: underline;">Yakozuna Clash and Ka..</span>
          </mj-text>

          <mj-text mj-class="fontSize-12 light" align="center" padding-bottom="4px">
            <!--Text-->
            Bonus Code:
          </mj-text>

          <mj-button href="https://mjml.io" target="_blank" width="140px" padding="0" css-class="card-item-btn" background-color="#2F2F3D" border="0" color="#FFFFFF"  font-size="14px" inner-padding="8px 24px">
            <!--Button-->
            Reactoonz_1
          </mj-button>
        </mj-column>
      </mj-section>

      <mj-section full-width="full-width" padding-bottom="24px"  mj-class="padding-section">
        <mj-column width="100%">
          <mj-text mj-class="fontSize-16" color="#B4BED8" align="center" font-weight="700">
            <!--TEXT-->
            Do the following to receive a bonus
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section full-width="full-width" padding="12px" css-class="bonus-steps">
      <mj-group>
        <mj-column css-class="bonus-steps-item-1"  vertical-align="middle" padding="0">
          <!--IMG GAME-->
          <mj-image src="./img/casino.jpg" alt="step" width="64px" height="64px"  align="left" />
        </mj-column>

        <mj-column  vertical-align="middle" padding="0" css-class="bonus-steps-item-2">
          <mj-text mj-class="fontSize-16 light" font-weight="700" align="left">
            <!--TEXT-->
            Step 1
          </mj-text>
          <mj-text mj-class="fontSize-14 " color="#B4BED8" align="left">
            <!--TEXT-->
            Take advantage of Bonus
          </mj-text>
        </mj-column>
        </mj-group>
      </mj-section>

    <!-- BR-->
      <mj-section padding-bottom="12px">
        <mj-column width="100%">
        </mj-column>
      </mj-section>

            <mj-section full-width="full-width" padding="12px" css-class="bonus-steps">
      <mj-group>
        <mj-column css-class="bonus-steps-item-1"  vertical-align="middle" padding="0">
          <!--IMG GAME-->
          <mj-image src="./img/casino.jpg" alt="step" width="64px" height="64px"  align="left" />
        </mj-column>

        <mj-column  vertical-align="middle" padding="0" css-class="bonus-steps-item-2">
          <mj-text mj-class="fontSize-16 light" font-weight="700" align="left">
            <!--TEXT-->
